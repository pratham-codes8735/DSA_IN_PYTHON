   "source": [
    "def linear_search(arr,target):\n",
    "    size= len(my_list)\n",
    "    for index in range(0,size):\n",
    "        if(arr[index]==target):\n",
    "            return index\n",
    "\n",
    "    return -1       \n",
    "\n",
    "my_list=[10,28,2,56,89,24,45]\n",
    "target=4\n",
    "\n",
    "result=linear_search(my_list , target)\n",
    "\n",
    "print(result)"
   ]
